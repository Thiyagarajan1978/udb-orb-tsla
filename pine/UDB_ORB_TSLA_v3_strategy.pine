//@version=6
strategy("UDB-ORB TSLA v3 STRATEGY — A1/B1/C1/C2 Profiles", shorttitle="UDB-ORB v3 S", overlay=true,
     process_orders_on_close = true,      // market orders fill at the SIGNAL BAR'S CLOSE (alerts-only realism)
     calc_on_every_tick      = false,
     pyramiding              = 0,
     default_qty_type        = strategy.fixed,
     default_qty_value       = 1,
     initial_capital         = 1000000,
     margin_long             = 0,
     margin_short            = 0,
     commission_type         = strategy.commission.cash_per_contract,
     commission_value        = 0,
     slippage                = 0,          // Python charges $0.10/unit on exits; set TV ~10 ticks to match
     max_labels_count        = 500)

// STATUS 2026-07-13: ONE strategy, FOUR selectable profiles (the "Profile" input). TSLA 5-minute, RTH,
// OR start 09:30 (selectable), 100 shares/unit. All share the SAME entry engine, resting stops (touch),
// vol/OR gates, risk-parity reversal, confirmation OFF. They differ ONLY in the exit:
//   A1 = Adaptive TP + 25% partial + PEAK-TRAIL runner        (Max Stop $5)
//   B1 = Adaptive TP + 25% partial + VWAP-CROSS runner        (Max Stop $5)
//   C1 = ATR-target (0.25 x 14d ATR) + 25% partial + VWAP     (Max Stop $6)   <- best PF
//   C2 = Fixed $2 target, FULL exit (no partial/runner)       (Max Stop $5)   <- highest win rate
//
//  EXECUTION MODEL — proper OCO brackets (all fills intrabar at the level / open-on-gap = touch):
//   * C2 (full exit): ONE strategy.exit("X", stop=, limit=) — whole position at stop OR target.
//   * A1/B1/C1 (partial+runner): "P1" = the 25% partial as an OCO(stop+target), "RUN" = the 75%
//     remainder on the stop (peak-trail A1 / VWAP-close B1,C1). BOTH legs carry a stop, so a stop-out
//     closes 100% (the earlier bug let a limit-only leg ride to EOD). Reversal arms only on a stop-out
//     before any partial (state part1/tpWasHit). See BE_STOP_ANALYSIS + memory (2026-07-13 TV fix).
//
//  SHARES PER UNIT (default 100): the reversal is risk-parity sized and needs FRACTIONAL units (e.g.
//  1.59); at 1 share/unit that rounds to 1 and the cap vanishes. With 100, 1.59 units = 159 shares.
//  ==> Strategy Tester P&L is ~100x the Python per-unit figures. Divide by 100 to compare.
//
//  PYTHON RECONCILE TARGETS (net @100 shares) — run the matching --config in cli.py:
//    Profile   FULL 2022-2026     365d (2025-07-14..2026-07-13)          Python config
//    A1          +80,140          +28,647  (287tr, 51%, PF 1.85)          config/config.yaml
//    B1         +100,668          +37,940  (287tr, 50%, PF 2.12)          config/tsla_best_B.yaml
//    C1          +98,912          +38,464  (283tr, 54%, PF 2.28)          config/tsla_config_C1.yaml
//    C2          +65,992          +16,824  (272tr, 65%, PF 1.76)          config/tsla_config_C.yaml
//  A stop-exit (Base SL / BE Stop / BE Trail) MUST appear in every profile's trade list, and the worst
//  loss must cap near the Max Stop ($5 or $6). If not, the OCO is misconfigured. Size off 2024, not 2026.
//
//  FULL 4.5-YEAR DECISION METRICS (2022-2026, @100 shares) — 365d is for TUNING, this is for DECIDING:
//    Profile   Net       PF     WinRate  WorstDay  MaxDrawdown  Net/MaxDD  LosingMonths
//    A1        +80,140   1.61   48%      -885      -3,320       24.1       9/53
//    B1       +100,668   1.76   47%      -885      -3,440       29.3       7/53   (max net)
//    C1        +98,912   1.79   48%      -936      -3,278       30.2       8/53   (BEST all-round)
//    C2        +65,992   1.69   57%      -836      -3,541       18.6      11/53   (high WR, weakest net/DD)
//  READ: C1 = best risk-adjusted (top PF, smallest drawdown, best net/DD, ~=B1 net). B1 = raw-net leader.
//  A1 = dominated by B1/C1. C2's 57% WR is a mirage (lowest net, WORST drawdown, most losing months -
//  it caps winners at $2 but still eats full stops). Every profile is positive in all 5 years.
//=============================================================================================

// ==================== PROFILE ====================
profile = input.string("C1 · ATR 0.25 + 25% Partial + VWAP", "Profile",
     options=["A1 · Adaptive + Peak-Trail", "B1 · Adaptive + VWAP", "C1 · ATR 0.25 + 25% Partial + VWAP", "C2 · Fixed $2 Full-Exit (max WR)"],
     group="Profile", tooltip="A1/B1 = adaptive OR-scaled target + 25% partial + runner (peak-trail vs VWAP). C1 = ATR-sized target + 25% partial + VWAP (best PF). C2 = flat $2 full exit, no partial/runner (highest win rate).")
isA1 = str.startswith(profile, "A1")
isB1 = str.startswith(profile, "B1")
isC1 = str.startswith(profile, "C1")
isC2 = str.startswith(profile, "C2")
tpModeSel  = isC2 ? "Fixed" : isC1 ? "ATR" : "Adaptive"
usePartial = not isC2                 // C2 is a full exit; A1/B1/C1 scale out 25%
runnerVWAP = isB1 or isC1             // true = VWAP-cross runner ; false = peak-trail (A1)

// ==================== INPUTS ====================
grpS = "Session"
eodHour = input.int(15, "EOD Exit Hour", minval=0, maxval=23, group=grpS)
eodMin  = input.int(50, "EOD Exit Minute", minval=0, maxval=59, group=grpS)
orStart = input.string("09:30", "Opening Range start bar", options=["09:30", "09:45"], group=grpS, tooltip="09:30 = classic first-bar OR. 09:45 = skip the noisy opening 15 min (better 2024/25 backtest, WORSE 2026).")

grpR = "Risk / Regime Gates"
maxORWidth  = input.float(8.0,  "Max OR Width ($) — skip wider days", step=0.5, group=grpR)
volLookback = input.int(20,     "Volatility Lookback (days)", minval=2, group=grpR)
maxRvolPct  = input.float(4.92, "Max Prior Realised Daily Vol (%)", step=0.01, group=grpR)

grpE = "Entry"
bufferPctOR = input.float(10.0, "Breakout Buffer (% of OR width)", step=0.5, group=grpE)
tradeQty    = input.float(1.0,  "Units Per Trade", minval=0.01, group=grpE)
unitScale   = input.int(100,    "Shares per 'unit'", minval=1, group=grpE, tooltip="Scale so fractional risk-parity reversal sizes survive whole-share rounding. Strategy Tester P&L = this x the Python per-unit figures.")

grpX = "Exit tuning (which apply depends on the Profile)"
maxCapOverride  = input.float(0.0,  "Max Stop override ($, 0 = use profile: C1=6 else 5)", step=0.5, group=grpX)
adaptiveTPScale = input.float(1.0,  "Adaptive TP — OR Width Multiplier (A1/B1)", step=0.05, group=grpX)
adaptiveTPMin   = input.float(2.14, "Adaptive TP — Minimum Floor $ (A1/B1)", step=0.01, group=grpX)
atrTPMult       = input.float(0.25, "ATR TP Multiplier x 14d ATR (C1)", step=0.01, group=grpX)
atrTPMin        = input.float(1.0,  "ATR TP Floor $ (C1)", step=0.25, group=grpX)
atrPeriod       = input.int(14,     "ATR Period (daily bars, C1)", minval=2, group=grpX)
fixedTP         = input.float(2.0,  "Fixed TP $ (C2)", step=0.25, group=grpX)
beTrigger       = input.float(0.55, "BE Retrace Trigger (% of OR width)", step=0.05, group=grpX)
beTrailAmt      = input.float(0.25, "BE Trail Amount ($)", step=0.01, group=grpX)
partialPct      = input.float(25.0, "Partial Exit Quantity % (A1/B1/C1)", step=1.0, group=grpX)
runnerMult      = input.float(0.75, "Runner Peak-Trail x OR width (A1)", step=0.05, group=grpX)
vwapArmProfit   = input.float(1.0,  "VWAP Cross — arm after profit $ (B1/C1)", step=0.25, group=grpX)

grpC = "Entry Confirmation"
confirmBreakout    = input.bool(false, "Require confirmation candle (2-candle break)", group=grpC, tooltip="DEFAULT OFF: net-negative under the resting stop.")
requireTrendCandle = input.bool(true,  "Confirmation candle must be with-trend", group=grpC)

grpV = "Reversal"
revQtyMult = input.float(2.0, "Reversal Size Multiplier (before risk cap)", step=0.5, group=grpV)
revRiskCap = input.float(6.0, "Reversal Dollar-Risk Cap ($, 0=off)", step=0.5, group=grpV)

grpU = "Display"
showLabels = input.bool(false, "Show Labels", group=grpU, tooltip="Turn OFF for 30/90/365-day runs (TradingView caps labels at 500).")
showLevels = input.bool(true, "Show Levels", group=grpU)

maxCapSL = maxCapOverride > 0 ? maxCapOverride : (isC1 ? 6.0 : 5.0)

// ==================== PRIOR-DAY VOL + DAILY ATR (no repaint) ====================
f_priorRvol() =>
    r = ta.change(close) / close[1] * 100.0
    s = ta.stdev(r, volLookback, false)
    s[1]
rvol20 = request.security(syminfo.tickerid, "D", f_priorRvol(), lookahead=barmerge.lookahead_on)
f_priorATR() =>
    a = ta.sma(ta.tr(true), atrPeriod)
    a[1]
dailyATR = request.security(syminfo.tickerid, "D", f_priorATR(), lookahead=barmerge.lookahead_on)

// ==================== STATE ====================
var float orHigh = na
var float orLow = na
var float orWidth = na
var bool skipVol = false
var bool skipWide = false
var bool daySkipped = false
var bool firstTaken = false
var bool active = false
var int tdir = 0
var float entry = na
var float stop = na
var float tp = na
var int entryBar = na
var bool inRev = false
var bool suppressPartial = false
var string entryId = ""
var bool beTrig = false
var float beLevel = na
var float qtyTotal = na
var bool part1 = false
var bool tpWasHit = false
var float runnerPeak = na
var bool vwapArmed = false
var bool lastWasTrail = false   // A1: was the last-placed runner stop the PEAK-TRAIL (reason "Trail",
                                // does NOT arm) vs the BE/base stop (arms)? mirrors engine stop-first order.
var int primDir = 0
var bool primStopped = false

// ==================== NEW DAY / OPENING RANGE ====================
isNewDay = session.isfirstbar_regular
isORbar = orStart == "09:45" ? (hour == 9 and minute == 45) : isNewDay
sessVwap = ta.vwap(hlc3, isNewDay)
isEODbar = (hour * 60 + minute) >= (eodHour * 60 + eodMin)
isLastBar = session.islastbar_regular
isFlattenBar = isEODbar or isLastBar

if isNewDay
    orHigh := na
    orLow := na
    orWidth := na
    daySkipped := false
    firstTaken := false
    active := false
    tdir := 0
    entry := na
    stop := na
    tp := na
    entryBar := na
    inRev := false
    suppressPartial := false
    entryId := ""
    beTrig := false
    beLevel := na
    qtyTotal := na
    part1 := false
    tpWasHit := false
    runnerPeak := na
    vwapArmed := false
    primDir := 0
    primStopped := false

if isORbar
    orHigh := high
    orLow := low
    orWidth := high - low
    skipVol := not na(rvol20) and rvol20 > maxRvolPct
    skipWide := orWidth > maxORWidth
    daySkipped := skipVol or skipWide

longBrk = not na(orHigh) ? orHigh + orWidth * bufferPctOR / 100.0 : na
shortBrk = not na(orLow) ? orLow - orWidth * bufferPctOR / 100.0 : na
// target distance by profile: Fixed (C2) / ATR (C1) / Adaptive OR-scaled (A1/B1)
tpDist = tpModeSel == "Fixed" ? fixedTP : tpModeSel == "ATR" ? (not na(dailyATR) ? math.max(atrTPMin, atrTPMult * dailyATR) : fixedTP) : (not na(orWidth) ? math.max(adaptiveTPMin, orWidth * adaptiveTPScale) : na)
canTrade = session.ismarket and not isORbar and not daySkipped and not na(orHigh) and not isFlattenBar

// ==================== PRIMARY ENTRY ====================
longConfirm  = not confirmBreakout or (close[1] > longBrk and (close >= open or not requireTrendCandle))
shortConfirm = not confirmBreakout or (close[1] < shortBrk and (close <= open or not requireTrendCandle))
if canTrade and not active and not firstTaken and strategy.position_size == 0
    if close > longBrk and longConfirm
        entryId := "L"
        strategy.entry(entryId, strategy.long, qty=tradeQty * unitScale)
        active := true
        tdir := 1
        inRev := false
        suppressPartial := false
        entry := close
        stop := maxCapSL > 0 ? math.max(orLow, close - maxCapSL) : orLow
        tp := close + tpDist
        beLevel := orHigh - beTrigger * orWidth
        entryBar := bar_index
        qtyTotal := tradeQty
        beTrig := false
        part1 := false
        tpWasHit := false
        runnerPeak := na
        vwapArmed := false
        primDir := 1
        firstTaken := true
        if showLabels
            label.new(bar_index, low, "LONG " + str.tostring(close, format.mintick), style=label.style_label_up, color=color.rgb(7,170,75), textcolor=color.white, size=size.small)
    else if close < shortBrk and shortConfirm
        entryId := "S"
        strategy.entry(entryId, strategy.short, qty=tradeQty * unitScale)
        active := true
        tdir := -1
        inRev := false
        suppressPartial := false
        entry := close
        stop := maxCapSL > 0 ? math.min(orHigh, close + maxCapSL) : orHigh
        tp := close - tpDist
        beLevel := orLow + beTrigger * orWidth
        entryBar := bar_index
        qtyTotal := tradeQty
        beTrig := false
        part1 := false
        tpWasHit := false
        runnerPeak := na
        vwapArmed := false
        primDir := -1
        firstTaken := true
        if showLabels
            label.new(bar_index, high, "SHORT " + str.tostring(close, format.mintick), style=label.style_label_down, color=color.rgb(243,76,76), textcolor=color.white, size=size.small)

// ==================== STATE DE-SYNC + REVERSAL ARMING (runs BEFORE the reversal entry) ============
// The OCO fills INTRABAR and is detected on the NEXT bar (position flat, active still true). This block
// MUST run before the reversal-entry block: a primary stop that fills on bar N is then armed here on N+1
// and the reversal can fire the SAME bar (N+1), matching orb_engine.py / the indicator. (When it ran
// AFTER the reversal block, arming happened a bar too late and the reversal entered ~1 bar worse -> it
// bled the reversal edge, ~35% of net.) Arm only on a BASE/BE STOP (reasons Base SL/BE Stop/BE Trail,
// L933): a peak-trail exit is reason "Trail" (lastWasTrail) and does NOT arm; C2 arms unless a TP win.
if active and strategy.position_size == 0 and bar_index > entryBar
    stoppedOut = usePartial ? (not lastWasTrail) : (not tpWasHit)
    if not inRev and stoppedOut
        primStopped := true
        if showLabels
            label.new(bar_index, tdir == 1 ? low : high, "REV armed: need close " + (tdir == 1 ? "< " + str.tostring(orLow, format.mintick) : "> " + str.tostring(orHigh, format.mintick)), style=tdir == 1 ? label.style_label_up : label.style_label_down, color=color.orange, textcolor=color.white, size=size.small)
    strategy.cancel("P1")
    strategy.cancel("RUN")
    strategy.cancel("X")
    active := false
    tdir := 0
    inRev := false
    tp := na
    stop := na
    vwapArmed := false

// ==================== REVERSAL ENTRY (raw OR break · trail-to-EOD · risk-parity · NO target) ====
if canTrade and primStopped and not active and strategy.position_size == 0
    if primDir == 1 and close < orLow
        rpu = math.abs(close - orHigh)
        rq = revRiskCap > 0 and rpu > 0 ? math.min(tradeQty * revQtyMult, revRiskCap / rpu) : tradeQty * revQtyMult
        entryId := "RS"
        strategy.entry(entryId, strategy.short, qty=rq * unitScale)
        active := true
        tdir := -1
        inRev := true
        suppressPartial := true
        entry := close
        stop := orHigh
        tp := na
        beLevel := orLow + beTrigger * orWidth
        entryBar := bar_index
        qtyTotal := rq
        beTrig := false
        part1 := false
        tpWasHit := false
        runnerPeak := na
        vwapArmed := false
        primStopped := false
        if showLabels
            label.new(bar_index, high, "REV SHORT " + str.tostring(close, format.mintick) + "\nqty " + str.tostring(rq, "#.##"), style=label.style_label_down, color=color.purple, textcolor=color.white, size=size.small)
    else if primDir == -1 and close > orHigh
        rpu = math.abs(close - orLow)
        rq = revRiskCap > 0 and rpu > 0 ? math.min(tradeQty * revQtyMult, revRiskCap / rpu) : tradeQty * revQtyMult
        entryId := "RL"
        strategy.entry(entryId, strategy.long, qty=rq * unitScale)
        active := true
        tdir := 1
        inRev := true
        suppressPartial := true
        entry := close
        stop := orLow
        tp := na
        beLevel := orHigh - beTrigger * orWidth
        entryBar := bar_index
        qtyTotal := rq
        beTrig := false
        part1 := false
        tpWasHit := false
        runnerPeak := na
        vwapArmed := false
        primStopped := false
        if showLabels
            label.new(bar_index, low, "REV LONG " + str.tostring(close, format.mintick) + "\nqty " + str.tostring(rq, "#.##"), style=label.style_label_up, color=color.purple, textcolor=color.white, size=size.small)

// ==================== EXIT ENGINE — OCO brackets (never on the entry bar) ====================
if active and not na(stop) and bar_index >= entryBar
    vwapExited = false
    if bar_index > entryBar
        // Step 1: BE Retrace (WICK trigger)
        if not beTrig and not na(beLevel)
            if (tdir == 1 ? low <= beLevel : high >= beLevel)
                stop := tdir == 1 ? math.max(stop, entry) : math.min(stop, entry)
                beTrig := true
        // Step 2: BE Trail
        if beTrig and beTrailAmt > 0
            stop := tdir == 1 ? math.max(stop, high - beTrailAmt) : math.min(stop, low + beTrailAmt)
        if usePartial
            // Step 3: mirror the 25% partial fill (P1 limit does the actual fill)
            if not suppressPartial and not part1 and not na(tp) and (tdir == 1 ? high >= tp : low <= tp)
                part1 := true
                tp := na
                if showLabels
                    label.new(bar_index, tdir == 1 ? high : low, "PARTIAL " + str.tostring(partialPct, "#") + "%", style=tdir == 1 ? label.style_label_down : label.style_label_up, color=color.rgb(7,170,75), textcolor=color.white, size=size.tiny)
            // Step 4a: runner peak-trail level (A1)
            if part1 and not suppressPartial and not runnerVWAP and runnerMult > 0
                runnerPeak := na(runnerPeak) ? (tdir == 1 ? high : low) : (tdir == 1 ? math.max(runnerPeak, high) : math.min(runnerPeak, low))
            // Step 4b: runner VWAP-cross exit (B1/C1)
            if part1 and not suppressPartial and runnerVWAP
                if not vwapArmed and (tdir == 1 ? close - entry : entry - close) >= vwapArmProfit
                    vwapArmed := true
                if vwapArmed and not na(sessVwap) and (tdir == 1 ? close <= sessVwap : close >= sessVwap)
                    strategy.cancel("P1")
                    strategy.cancel("RUN")
                    strategy.close(entryId, comment=(inRev ? "REV VWAP" : "VWAP Cross"))
                    if showLabels
                        label.new(bar_index, tdir == 1 ? high : low, (inRev ? "REV " : "") + "VWAP " + str.tostring(close, format.mintick), style=tdir == 1 ? label.style_label_down : label.style_label_up, color=color.new(color.aqua, 0), textcolor=color.white, size=size.small)
                    active := false
                    tdir := 0
                    inRev := false
                    tp := na
                    stop := na
                    vwapArmed := false
                    vwapExited := true
        else
            // C2 full exit: mirror the target touch so a TP win does not arm the reversal
            if not na(tp) and (tdir == 1 ? high >= tp : low <= tp)
                tpWasHit := true
    if not vwapExited
        beReason = beTrig ? ((tdir == 1 ? stop > entry : stop < entry) ? "BE Trail" : "BE Stop") : "Base SL"
        if not usePartial
            // C2: ONE OCO bracket for the whole position (stop OR target)
            strategy.exit("X", from_entry=entryId, stop=stop, limit=tp, comment_loss=(inRev ? "REV " : "") + beReason, comment_profit=(inRev ? "REV TP" : "TP"))
        else
            trailLevel = (part1 and not suppressPartial and not runnerVWAP and runnerMult > 0 and not na(runnerPeak)) ? (tdir == 1 ? runnerPeak - runnerMult * orWidth : runnerPeak + runnerMult * orWidth) : na
            if suppressPartial
                lastWasTrail := false
                strategy.exit("RUN", from_entry=entryId, stop=stop, comment=(inRev ? "REV " : "") + beReason)
            else if not part1
                lastWasTrail := false
                strategy.exit("P1", from_entry=entryId, qty_percent=partialPct, stop=stop, limit=tp, comment_loss=(inRev ? "REV " : "") + beReason, comment_profit="Partial @ TP")
                strategy.exit("RUN", from_entry=entryId, stop=stop, comment=(inRev ? "REV " : "") + beReason)
            else
                runnerStop = na(trailLevel) ? stop : (tdir == 1 ? math.max(stop, trailLevel) : math.min(stop, trailLevel))
                isTrail = not na(trailLevel) and (tdir == 1 ? trailLevel >= stop : trailLevel <= stop)
                lastWasTrail := isTrail
                strategy.exit("RUN", from_entry=entryId, stop=runnerStop, comment=(inRev ? "REV " : "") + (isTrail ? "Trail" : beReason))

// ==================== EOD FORCED CLOSE ====================
if active and isFlattenBar and tdir != 0
    strategy.cancel("P1")
    strategy.cancel("RUN")
    strategy.cancel("X")
    strategy.close(entryId, comment=(inRev ? "REV EOD" : "EOD"))
    if showLabels
        label.new(bar_index, close, (inRev ? "REV EOD " : "EOD ") + str.tostring(close, format.mintick), style=label.style_label_left, color=color.rgb(255,140,0), textcolor=color.white, size=size.small)
    active := false
    tdir := 0
    inRev := false
    tp := na
    stop := na

if strategy.position_size != 0 and isFlattenBar and not active
    strategy.close_all(comment="EOD flat")

// ==================== VISUALS ====================
plot(showLevels and not daySkipped and not na(orHigh) ? orHigh : na, "OR High", color=color.new(color.aqua, 0), style=plot.style_linebr)
plot(showLevels and not daySkipped and not na(orLow) ? orLow : na, "OR Low", color=color.new(color.aqua, 0), style=plot.style_linebr)
plot(showLevels and not daySkipped and not na(longBrk) ? longBrk : na, "Long Trigger", color=color.new(color.lime, 0), style=plot.style_linebr)
plot(showLevels and not daySkipped and not na(shortBrk) ? shortBrk : na, "Short Trigger", color=color.new(color.red, 0), style=plot.style_linebr)
plot(active ? stop : na, "Active Stop", color=color.red, linewidth=2, style=plot.style_linebr)
plot(active and not na(tp) ? tp : na, "Active TP", color=color.lime, linewidth=2, style=plot.style_linebr)
plot(active and not beTrig and not na(beLevel) ? beLevel : na, "BE Trigger", color=color.new(color.yellow, 0), style=plot.style_circles)
plot(primStopped and not active ? (primDir == 1 ? orLow : orHigh) : na, "Reversal Trigger", color=color.new(color.purple, 0), linewidth=2, style=plot.style_circles)
bgcolor(daySkipped ? color.new(color.gray, 90) : na, title="Day skipped (vol regime / wide OR)")

// ==================== INFO TABLE ====================
var table t = table.new(position.top_right, 2, 5, border_width=1)
if barstate.islast
    table.cell(t, 0, 0, "UDB-ORB v3", text_color=color.white, bgcolor=color.rgb(30,30,50), text_size=size.small)
    table.cell(t, 1, 0, str.substring(profile, 0, 2), text_color=color.aqua, bgcolor=color.rgb(30,30,50), text_size=size.small)
    table.cell(t, 0, 1, "TP mode / Max Stop", text_color=color.white, bgcolor=color.rgb(25,25,25), text_size=size.small)
    table.cell(t, 1, 1, tpModeSel + " / $" + str.tostring(maxCapSL, "#"), text_color=color.aqua, bgcolor=color.rgb(25,25,25), text_size=size.small)
    table.cell(t, 0, 2, "Today's TP dist", text_color=color.white, bgcolor=color.rgb(25,25,25), text_size=size.small)
    table.cell(t, 1, 2, na(tpDist) ? "n/a" : "$" + str.tostring(tpDist, "#.##"), text_color=color.aqua, bgcolor=color.rgb(25,25,25), text_size=size.small)
    table.cell(t, 0, 3, "RVol (gate ≤ " + str.tostring(maxRvolPct, "#.##") + "%)", text_color=color.white, bgcolor=color.rgb(25,25,25), text_size=size.small)
    table.cell(t, 1, 3, na(rvol20) ? "n/a" : str.tostring(rvol20, "#.##") + "%", text_color=skipVol ? color.red : color.lime, bgcolor=color.rgb(25,25,25), text_size=size.small)
    table.cell(t, 0, 4, "Today", text_color=color.white, bgcolor=color.rgb(25,25,25), text_size=size.small)
    table.cell(t, 1, 4, daySkipped ? "SKIPPED" : "tradable", text_color=daySkipped ? color.red : color.lime, bgcolor=color.rgb(25,25,25), text_size=size.small)
