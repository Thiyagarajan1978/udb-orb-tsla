//@version=6
indicator("UDB-ORB TSLA v3 - A1/B1/C1/C2 Profiles", shorttitle="UDB-ORB v3", overlay=true, max_labels_count=500)

// STATUS 2026-07-13: ONE indicator, FOUR selectable profiles (fires ALERTS; identical logic to the v3
// STRATEGY). TSLA 5-minute, RTH, OR start 09:30 (selectable), 100 shares/unit. Same entry engine,
// resting stops, vol/OR gates, risk-parity reversal for all. They differ ONLY in the exit:
//   A1 = Adaptive TP + 25% partial + PEAK-TRAIL runner   (Max Stop $5)
//   B1 = Adaptive TP + 25% partial + VWAP-CROSS runner   (Max Stop $5)
//   C1 = ATR-target (0.25x14d ATR) + 25% partial + VWAP  (Max Stop $6)   <- best PF
//   C2 = Fixed $2 target, FULL exit (no partial/runner)  (Max Stop $5)   <- highest win rate
//  PYTHON RECONCILE (net per 1 unit; x100 for the strategy at 100 sh): FULL 2022-2026 -> A1 +801, B1
//  +1007, C1 +989, C2 +660. Table Net P&L is per 1 unit. Size off 2024/2025, not the flattering 2026.
//  4.5-YEAR DECISION (@100sh): PF A1 1.61 / B1 1.76 / C1 1.79 / C2 1.69 ; MaxDrawdown A1 -3,320 /
//  B1 -3,440 / C1 -3,278 / C2 -3,541. C1 = best risk-adjusted (top PF + smallest DD, ~=B1 net). B1 =
//  max net. A1 dominated. C2 = high win rate (57%) but lowest net & worst drawdown (a mirage). All +ve
//  every year 2022-2026. 365 days is for TUNING; judge go/no-go on the full 4.5-year picture.
//=============================================================================================

// ==================== PROFILE ====================
profile = input.string("C1 · ATR 0.25 + 25% Partial + VWAP", "Profile",
     options=["A1 · Adaptive + Peak-Trail", "B1 · Adaptive + VWAP", "C1 · ATR 0.25 + 25% Partial + VWAP", "C2 · Fixed $2 Full-Exit (max WR)"], group="Profile")
isA1 = str.startswith(profile, "A1")
isB1 = str.startswith(profile, "B1")
isC1 = str.startswith(profile, "C1")
isC2 = str.startswith(profile, "C2")
tpModeSel  = isC2 ? "Fixed" : isC1 ? "ATR" : "Adaptive"
usePartial = not isC2
runnerVWAP = isB1 or isC1

// ==================== INPUTS ====================
grpS = "Session"
eodHour = input.int(15, "EOD Exit Hour", minval=0, maxval=23, group=grpS)
eodMin  = input.int(50, "EOD Exit Minute", minval=0, maxval=59, group=grpS)
orStart = input.string("09:30", "Opening Range start bar", options=["09:30", "09:45"], group=grpS)

grpR = "Risk / Regime Gates"
maxORWidth  = input.float(8.0,  "Max OR Width ($) — skip wider days", step=0.5, group=grpR)
volLookback = input.int(20,     "Volatility Lookback (days)", minval=2, group=grpR)
maxRvolPct  = input.float(4.92, "Max Prior Realised Daily Vol (%)", step=0.01, group=grpR)

grpE = "Entry"
bufferPctOR = input.float(10.0, "Breakout Buffer (% of OR width)", step=0.5, group=grpE)
tradeQty    = input.float(1.0,  "Units Per Trade", minval=0.01, group=grpE)
slippage    = input.float(0.10, "Slippage Per Unit (charged on each exit)", step=0.01, group=grpE)

grpX = "Exit tuning (which apply depends on the Profile)"
maxCapOverride  = input.float(0.0,  "Max Stop override ($, 0 = use profile: C1=6 else 5)", step=0.5, group=grpX)
adaptiveTPScale = input.float(1.0,  "Adaptive TP — OR Width Multiplier (A1/B1)", step=0.05, group=grpX)
adaptiveTPMin   = input.float(2.14, "Adaptive TP — Minimum Floor $ (A1/B1)", step=0.01, group=grpX)
atrTPMult       = input.float(0.25, "ATR TP Multiplier x 14d ATR (C1)", step=0.01, group=grpX)
atrTPMin        = input.float(1.0,  "ATR TP Floor $ (C1)", step=0.25, group=grpX)
atrPeriod       = input.int(14,     "ATR Period (daily bars, C1)", minval=2, group=grpX)
fixedTP         = input.float(2.0,  "Fixed TP $ (C2)", step=0.25, group=grpX)
beTrigger       = input.float(0.55, "BE Retrace Trigger (% of OR width)", step=0.05, group=grpX)
beTrailAmt      = input.float(0.25, "BE Trail Amount ($)", step=0.01, group=grpX)
partialPct      = input.float(25.0, "Partial Exit Quantity % (A1/B1/C1)", step=1.0, group=grpX)
runnerMult      = input.float(0.75, "Runner Peak-Trail x OR width (A1)", step=0.05, group=grpX)
vwapArmProfit   = input.float(1.0,  "VWAP Cross — arm after profit $ (B1/C1)", step=0.25, group=grpX)
exitOnClose     = input.bool(false, "Stop exits fill at bar CLOSE (OFF = resting stop)", group=grpX)
beRealistic     = input.bool(true,  "Realistic resting stop: a BE-retrace can't protect its own firing bar", group=grpX, tooltip="ON (default) = matches a real broker + Python stop_fill_mode 'resting': moving the stop to break-even on the bar close only rests from the NEXT bar, so a bar that both fires the BE-retrace AND crashes to the base SL fills at the base SL. OFF = the old optimistic look-ahead (over-reports net ~40-45%).")

grpC = "Entry Confirmation"
confirmBreakout    = input.bool(false, "Require confirmation candle (2-candle break)", group=grpC)
requireTrendCandle = input.bool(true,  "Confirmation candle must be with-trend", group=grpC)

grpV = "Reversal"
revQtyMult = input.float(2.0, "Reversal Size Multiplier (before risk cap)", step=0.5, group=grpV)
revRiskCap = input.float(6.0, "Reversal Dollar-Risk Cap ($, 0=off)", step=0.5, group=grpV)

grpU = "Display"
showLabels = input.bool(true, "Show Entry/Exit Labels", group=grpU)
showLevels = input.bool(true, "Show OR / Trigger Levels", group=grpU)
showTable  = input.bool(true, "Show Summary Table", group=grpU)

maxCapSL = maxCapOverride > 0 ? maxCapOverride : (isC1 ? 6.0 : 5.0)

// ==================== PRIOR-DAY VOL + DAILY ATR (no repaint) ====================
f_priorRvol() =>
    r = ta.change(close) / close[1] * 100.0
    s = ta.stdev(r, volLookback, false)
    s[1]
rvol20 = request.security(syminfo.tickerid, "D", f_priorRvol(), lookahead=barmerge.lookahead_on)
f_priorATR() =>
    a = ta.sma(ta.tr(true), atrPeriod)
    a[1]
dailyATR = request.security(syminfo.tickerid, "D", f_priorATR(), lookahead=barmerge.lookahead_on)

// ==================== STATE ====================
var float orHigh = na
var float orLow = na
var float orWidth = na
var bool skipVol = false
var bool skipWide = false
var bool daySkipped = false
var bool firstTaken = false
var bool active = false
var int tdir = 0
var float entry = na
var float stop = na
var float tp = na
var int entryBar = na
var bool inRev = false
var bool suppressPartial = false
var bool beTrig = false
var float beLevel = na
var bool part1 = false
var bool vwapArmed = false
var float qtyTotal = na
var float effQty = na
var float part1Pnl = 0.0
var float runnerPeak = na
var int primDir = 0
var bool primStopped = false
var float dayPnl = 0.0
var bool dayHasTrades = false
var int nTrades = 0
var int nSucc = 0
var int nFail = 0
var float netPnl = 0.0
var float grossP = 0.0
var float grossL = 0.0
var float worstDay = na
var float bestDay = na
var int totalDays = 0
var int tradeDays = 0
var int volSkipDays = 0
var int wideSkipDays = 0
var int cStop = 0
var int cWin = 0
var int cEOD = 0
var int cRev = 0

aEntryL = false
aEntryS = false
aRevL = false
aRevS = false
aBEFired = false
aPart = false
aWin = false
aStop = false
aEOD = false

// ==================== NEW DAY / OPENING RANGE ====================
isNewDay = session.isfirstbar_regular
isORbar = orStart == "09:45" ? (hour == 9 and minute == 45) : isNewDay
sessVwap = ta.vwap(hlc3, isNewDay)
isEODbar = (hour * 60 + minute) >= (eodHour * 60 + eodMin)
isLastBar = session.islastbar_regular          // half-day / early close: flatten on the session's LAST bar even if 15:50 never prints
isFlattenBar = isEODbar or isLastBar

if isNewDay
    if dayHasTrades
        worstDay := na(worstDay) ? dayPnl : math.min(worstDay, dayPnl)
        bestDay := na(bestDay) ? dayPnl : math.max(bestDay, dayPnl)
        tradeDays += 1
    totalDays += 1
    dayPnl := 0.0
    dayHasTrades := false
    orHigh := na
    orLow := na
    orWidth := na
    daySkipped := false
    firstTaken := false
    active := false
    tdir := 0
    entry := na
    stop := na
    tp := na
    entryBar := na
    inRev := false
    suppressPartial := false
    beTrig := false
    beLevel := na
    part1 := false
    vwapArmed := false
    qtyTotal := na
    effQty := na
    part1Pnl := 0.0
    runnerPeak := na
    primDir := 0
    primStopped := false

if isORbar
    orHigh := high
    orLow := low
    orWidth := high - low
    skipVol := not na(rvol20) and rvol20 > maxRvolPct
    skipWide := orWidth > maxORWidth
    daySkipped := skipVol or skipWide
    if skipVol
        volSkipDays += 1
    else if skipWide
        wideSkipDays += 1

longBrk = not na(orHigh) ? orHigh + orWidth * bufferPctOR / 100.0 : na
shortBrk = not na(orLow) ? orLow - orWidth * bufferPctOR / 100.0 : na
tpDist = tpModeSel == "Fixed" ? fixedTP : tpModeSel == "ATR" ? (not na(dailyATR) ? math.max(atrTPMin, atrTPMult * dailyATR) : fixedTP) : (not na(orWidth) ? math.max(adaptiveTPMin, orWidth * adaptiveTPScale) : na)
canTrade = session.ismarket and not isORbar and not daySkipped and not na(orHigh) and not isFlattenBar

longConfirm  = not confirmBreakout or (close[1] > longBrk and (close >= open or not requireTrendCandle))
shortConfirm = not confirmBreakout or (close[1] < shortBrk and (close <= open or not requireTrendCandle))

// ==================== PRIMARY ENTRY ====================
if canTrade and not active and not firstTaken
    if close > longBrk and longConfirm
        active := true
        tdir := 1
        inRev := false
        suppressPartial := false
        entry := close
        stop := maxCapSL > 0 ? math.max(orLow, close - maxCapSL) : orLow
        tp := close + tpDist
        beLevel := orHigh - beTrigger * orWidth
        entryBar := bar_index
        qtyTotal := tradeQty
        effQty := tradeQty
        part1 := false
        part1Pnl := 0.0
        beTrig := false
        runnerPeak := na
        vwapArmed := false
        primDir := 1
        firstTaken := true
        aEntryL := true
        if showLabels
            label.new(bar_index, low, "LONG " + str.tostring(entry, format.mintick), style=label.style_label_up, color=color.rgb(7,170,75), textcolor=color.white, size=size.small)
    else if close < shortBrk and shortConfirm
        active := true
        tdir := -1
        inRev := false
        suppressPartial := false
        entry := close
        stop := maxCapSL > 0 ? math.min(orHigh, close + maxCapSL) : orHigh
        tp := close - tpDist
        beLevel := orLow + beTrigger * orWidth
        entryBar := bar_index
        qtyTotal := tradeQty
        effQty := tradeQty
        part1 := false
        part1Pnl := 0.0
        beTrig := false
        runnerPeak := na
        vwapArmed := false
        primDir := -1
        firstTaken := true
        aEntryS := true
        if showLabels
            label.new(bar_index, high, "SHORT " + str.tostring(entry, format.mintick), style=label.style_label_down, color=color.rgb(243,76,76), textcolor=color.white, size=size.small)

// ==================== REVERSAL ENTRY ====================
if canTrade and primStopped and not active
    if primDir == 1 and close < orLow
        rpu = math.abs(close - orHigh)
        rq = revRiskCap > 0 and rpu > 0 ? math.min(tradeQty * revQtyMult, revRiskCap / rpu) : tradeQty * revQtyMult
        active := true
        tdir := -1
        inRev := true
        suppressPartial := true
        entry := close
        stop := orHigh
        tp := na
        beLevel := orLow + beTrigger * orWidth
        entryBar := bar_index
        qtyTotal := rq
        effQty := rq
        part1 := false
        part1Pnl := 0.0
        beTrig := false
        runnerPeak := na
        primStopped := false
        cRev += 1
        aRevS := true
        if showLabels
            label.new(bar_index, high, "REV SHORT " + str.tostring(entry, format.mintick) + "\nqty " + str.tostring(rq, "#.##"), style=label.style_label_down, color=color.purple, textcolor=color.white, size=size.small)
    else if primDir == -1 and close > orHigh
        rpu = math.abs(close - orLow)
        rq = revRiskCap > 0 and rpu > 0 ? math.min(tradeQty * revQtyMult, revRiskCap / rpu) : tradeQty * revQtyMult
        active := true
        tdir := 1
        inRev := true
        suppressPartial := true
        entry := close
        stop := orLow
        tp := na
        beLevel := orHigh - beTrigger * orWidth
        entryBar := bar_index
        qtyTotal := rq
        effQty := rq
        part1 := false
        part1Pnl := 0.0
        beTrig := false
        runnerPeak := na
        primStopped := false
        cRev += 1
        aRevL := true
        if showLabels
            label.new(bar_index, low, "REV LONG " + str.tostring(entry, format.mintick) + "\nqty " + str.tostring(rq, "#.##"), style=label.style_label_up, color=color.purple, textcolor=color.white, size=size.small)

// ==================== EXIT ENGINE (simulated; stop-first; never on the entry bar) ====================
if active and not na(stop) and bar_index > entryBar
    stopBarStart = stop        // the stop that was actually RESTING coming into this bar
    beFiredNow = false
    // Step 1: BE Retrace
    if not beTrig and not na(beLevel)
        if (tdir == 1 ? low <= beLevel : high >= beLevel)
            stop := tdir == 1 ? math.max(stop, entry) : math.min(stop, entry)
            beTrig := true
            aBEFired := true
            beFiredNow := true
    // Step 2: BE Trail
    if beTrig and beTrailAmt > 0
        stop := tdir == 1 ? math.max(stop, high - beTrailAmt) : math.min(stop, low + beTrailAmt)
    // Step 3: runner level (only after the partial, only for A1/B1/C1)
    runnerHit = false
    float runnerPx = na
    string runnerReason = "Trail"
    if usePartial and part1 and not suppressPartial and runnerVWAP
        if not vwapArmed and (tdir == 1 ? close - entry : entry - close) >= vwapArmProfit
            vwapArmed := true
        if vwapArmed and not na(sessVwap) and (tdir == 1 ? close <= sessVwap : close >= sessVwap)
            runnerHit := true
            runnerPx := close
            runnerReason := "VWAP Cross"
    else if usePartial and part1 and not suppressPartial and not runnerVWAP and runnerMult > 0
        if tdir == 1
            runnerPeak := na(runnerPeak) ? high : math.max(runnerPeak, high)
            lvl = runnerPeak - runnerMult * orWidth
            if exitOnClose ? close <= lvl : low <= lvl
                runnerHit := true
                runnerPx := exitOnClose ? close : lvl
        else
            runnerPeak := na(runnerPeak) ? low : math.min(runnerPeak, low)
            lvl = runnerPeak + runnerMult * orWidth
            if exitOnClose ? close >= lvl : high >= lvl
                runnerHit := true
                runnerPx := exitOnClose ? close : lvl
    // Step 4: hit checks — STOP FIRST (matches the engine), then target, then partial, then runner
    // resting-stop realism: a BE-retrace that fired THIS bar cannot protect it — fill against the
    // pre-retrace stop (the level actually resting coming into the bar).
    restStop = (beRealistic and beFiredNow) ? stopBarStart : stop
    slHit = tdir == 1 ? (exitOnClose ? close <= restStop : low <= restStop) : (exitOnClose ? close >= restStop : high >= restStop)
    slFill = exitOnClose ? close : (tdir == 1 ? math.min(restStop, open) : math.max(restStop, open))
    tpHit = not na(tp) and (tdir == 1 ? high >= tp : low <= tp)

    if slHit
        exitPx = slFill
        perUnit = tdir == 1 ? (exitPx - entry - slippage) : (entry - exitPx - slippage)
        pnlTotal = perUnit * effQty + part1Pnl
        isBETrail = beTrig and (tdir == 1 ? exitPx > entry : exitPx < entry)
        reason = beTrig ? (isBETrail ? "BE Trail" : "BE Stop") : "Base SL"
        cStop += 1
        aStop := true
        nTrades += 1
        if pnlTotal > 0
            nSucc += 1
            grossP += pnlTotal
        else
            nFail += 1
            grossL += math.abs(pnlTotal)
        netPnl += pnlTotal
        dayPnl += pnlTotal
        dayHasTrades := true
        if not inRev
            // Arms on the STOP-HIT bar (immediate), so the reversal fires on the NEXT bar (N+1) - matches
            // orb_engine.py L933 and the v3 STRATEGY (whose de-sync/arming was reordered 2026-07-13 to also
            // arm on N+1). Base SL / BE Stop / BE Trail arm; peak-trail ("Trail") / VWAP / TP / EOD do not.
            primStopped := true
        if showLabels
            label.new(bar_index, tdir == 1 ? low : high, (inRev ? "REV " : "") + reason + " " + str.tostring(exitPx, format.mintick) + "\n" + (pnlTotal >= 0 ? "+" : "") + str.tostring(pnlTotal, "#.##"), style=tdir == 1 ? label.style_label_up : label.style_label_down, color=isBETrail ? color.rgb(7,170,75) : color.orange, textcolor=color.white, size=size.small)
        active := false
        tdir := 0
        inRev := false
        tp := na
        stop := na
    else if usePartial and tpHit and not part1
        p1qty = qtyTotal * partialPct / 100.0
        pu = tdir == 1 ? (tp - entry - slippage) : (entry - tp - slippage)
        part1Pnl := pu * p1qty
        effQty := qtyTotal - p1qty
        part1 := true
        aPart := true
        if showLabels
            label.new(bar_index, tdir == 1 ? high : low, "PARTIAL " + str.tostring(partialPct, "#") + "% @ " + str.tostring(tp, format.mintick) + "\n+" + str.tostring(part1Pnl, "#.##"), style=tdir == 1 ? label.style_label_down : label.style_label_up, color=color.rgb(7,170,75), textcolor=color.white, size=size.tiny)
        tp := na
    else if (not usePartial) and tpHit
        // C2 full exit at the target
        exitPx = tp
        perUnit = tdir == 1 ? (exitPx - entry - slippage) : (entry - exitPx - slippage)
        pnlTotal = perUnit * effQty
        cWin += 1
        aWin := true
        nTrades += 1
        if pnlTotal > 0
            nSucc += 1
            grossP += pnlTotal
        else
            nFail += 1
            grossL += math.abs(pnlTotal)
        netPnl += pnlTotal
        dayPnl += pnlTotal
        dayHasTrades := true
        if showLabels
            label.new(bar_index, tdir == 1 ? high : low, (inRev ? "REV " : "") + "TP " + str.tostring(exitPx, format.mintick) + "\n+" + str.tostring(pnlTotal, "#.##"), style=tdir == 1 ? label.style_label_down : label.style_label_up, color=color.new(color.lime, 0), textcolor=color.white, size=size.small)
        active := false
        tdir := 0
        inRev := false
        tp := na
        stop := na
    else if runnerHit
        exitPx = runnerPx
        perUnit = tdir == 1 ? (exitPx - entry - slippage) : (entry - exitPx - slippage)
        pnlTotal = perUnit * effQty + part1Pnl
        cWin += 1
        aWin := true
        nTrades += 1
        if pnlTotal > 0
            nSucc += 1
            grossP += pnlTotal
        else
            nFail += 1
            grossL += math.abs(pnlTotal)
        netPnl += pnlTotal
        dayPnl += pnlTotal
        dayHasTrades := true
        if showLabels
            label.new(bar_index, tdir == 1 ? high : low, (inRev ? "REV " : "") + runnerReason + " " + str.tostring(exitPx, format.mintick) + "\n" + (pnlTotal >= 0 ? "+" : "") + str.tostring(pnlTotal, "#.##"), style=tdir == 1 ? label.style_label_down : label.style_label_up, color=color.new(color.aqua, 0), textcolor=color.white, size=size.small)
        active := false
        tdir := 0
        inRev := false
        tp := na
        stop := na

// ==================== EOD FORCED CLOSE (all profiles; half-day = session last bar) ====================
if active and isFlattenBar and tdir != 0
    exitPx = close
    perUnit = tdir == 1 ? (exitPx - entry - slippage) : (entry - exitPx - slippage)
    pnlTotal = perUnit * effQty + part1Pnl
    cEOD += 1
    aEOD := true
    nTrades += 1
    if pnlTotal > 0
        nSucc += 1
        grossP += pnlTotal
    else
        nFail += 1
        grossL += math.abs(pnlTotal)
    netPnl += pnlTotal
    dayPnl += pnlTotal
    dayHasTrades := true
    if showLabels
        label.new(bar_index, close, (inRev ? "REV EOD " : "EOD ") + str.tostring(exitPx, format.mintick) + "\n" + (pnlTotal >= 0 ? "+" : "") + str.tostring(pnlTotal, "#.##"), style=label.style_label_left, color=color.rgb(255,140,0), textcolor=color.white, size=size.small)
    active := false
    tdir := 0
    inRev := false
    tp := na
    stop := na

// ==================== VISUALS ====================
plot(showLevels and not daySkipped and not na(orHigh) ? orHigh : na, "OR High", color=color.new(color.aqua, 0), style=plot.style_linebr)
plot(showLevels and not daySkipped and not na(orLow) ? orLow : na, "OR Low", color=color.new(color.aqua, 0), style=plot.style_linebr)
plot(showLevels and not daySkipped and not na(longBrk) ? longBrk : na, "Long Trigger", color=color.new(color.lime, 0), style=plot.style_linebr)
plot(showLevels and not daySkipped and not na(shortBrk) ? shortBrk : na, "Short Trigger", color=color.new(color.red, 0), style=plot.style_linebr)
plot(active ? stop : na, "Active Stop", color=color.red, linewidth=2, style=plot.style_linebr)
plot(active and not na(tp) ? tp : na, "Active TP", color=color.lime, linewidth=2, style=plot.style_linebr)
plot(active and not beTrig and not na(beLevel) ? beLevel : na, "BE Trigger", color=color.new(color.yellow, 0), style=plot.style_circles)
plot(primStopped and not active ? (primDir == 1 ? orLow : orHigh) : na, "Reversal Trigger", color=color.new(color.purple, 0), linewidth=2, style=plot.style_circles)
bgcolor(daySkipped ? color.new(color.gray, 90) : na, title="Day skipped")

// ==================== ALERTS ====================
if barstate.isconfirmed
    base = " | " + str.substring(profile, 0, 2) + " | " + syminfo.ticker + " " + timeframe.period + "m | Px $" + str.tostring(close, "#.##") + " | " + str.format_time(time, "yyyy-MM-dd HH:mm", "America/New_York") + " ET"
    if aEntryL
        alert("[ENTRY] LONG breakout — BUY at market" + base, alert.freq_once_per_bar)
    if aEntryS
        alert("[ENTRY] SHORT breakout — SELL SHORT at market" + base, alert.freq_once_per_bar)
    if aRevL
        alert("[ENTRY-REV] REVERSAL LONG (risk-parity size) — BUY at market" + base, alert.freq_once_per_bar)
    if aRevS
        alert("[ENTRY-REV] REVERSAL SHORT (risk-parity size) — SELL SHORT at market" + base, alert.freq_once_per_bar)
    if aBEFired
        alert("[STATE] BE RETRACE FIRED — move stop to ENTRY" + base, alert.freq_once_per_bar)
    if aPart
        alert("[EXIT-PARTIAL] 25% closed at target; runner now governs" + base, alert.freq_once_per_bar)
    if aWin
        alert("[EXIT-WIN] target / runner exit — close remaining position" + base, alert.freq_once_per_bar)
    if aStop
        alert("[EXIT-STOP] stop hit — close position (Base SL / BE Stop / BE Trail)" + base, alert.freq_once_per_bar)
    if aEOD
        alert("[EXIT-EOD] End-of-day forced close" + base, alert.freq_once_per_bar)

// ==================== NAMED ALERTS — per Profile x Status (pick in TradingView's "Add alert" dialog) ==========
// The alert() calls above fire the single generic "Any alert() function call". The alertcondition() calls
// below add NAMED, individually-selectable alerts. Each is gated by the SELECTED profile, so only your active
// profile's alerts can ever fire (on a B1 chart the A1/C1/C2 rows stay silent). Set frequency "Once Per Bar Close".
// --- A1 · Adaptive + Peak-Trail ---
alertcondition(isA1 and aEntryL,  title="A1 Buy",      message="A1 BUY - long breakout, buy at market | {{ticker}} {{interval}}m @ {{close}}")
alertcondition(isA1 and aEntryS,  title="A1 Sell",     message="A1 SELL - short breakout, sell short at market | {{ticker}} {{interval}}m @ {{close}}")
alertcondition(isA1 and aRevL,    title="A1 Rev Buy",  message="A1 REVERSAL BUY - risk-parity long at market | {{ticker}} {{interval}}m @ {{close}}")
alertcondition(isA1 and aRevS,    title="A1 Rev Sell", message="A1 REVERSAL SELL - risk-parity short at market | {{ticker}} {{interval}}m @ {{close}}")
alertcondition(isA1 and aBEFired, title="A1 BE",       message="A1 BREAK-EVEN - move stop to entry | {{ticker}} {{interval}}m @ {{close}}")
alertcondition(isA1 and aPart,    title="A1 Partial",  message="A1 PARTIAL - 25% closed at target; runner governs | {{ticker}} {{interval}}m @ {{close}}")
alertcondition(isA1 and aWin,     title="A1 TP",       message="A1 TP - close remaining (target/runner win) | {{ticker}} {{interval}}m @ {{close}}")
alertcondition(isA1 and aStop,    title="A1 SL",       message="A1 SL - close position (stop hit) | {{ticker}} {{interval}}m @ {{close}}")
alertcondition(isA1 and aEOD,     title="A1 EOD",      message="A1 EOD - end-of-day forced close | {{ticker}} {{interval}}m @ {{close}}")
// --- B1 · Adaptive + VWAP runner ---
alertcondition(isB1 and aEntryL,  title="B1 Buy",      message="B1 BUY - long breakout, buy at market | {{ticker}} {{interval}}m @ {{close}}")
alertcondition(isB1 and aEntryS,  title="B1 Sell",     message="B1 SELL - short breakout, sell short at market | {{ticker}} {{interval}}m @ {{close}}")
alertcondition(isB1 and aRevL,    title="B1 Rev Buy",  message="B1 REVERSAL BUY - risk-parity long at market | {{ticker}} {{interval}}m @ {{close}}")
alertcondition(isB1 and aRevS,    title="B1 Rev Sell", message="B1 REVERSAL SELL - risk-parity short at market | {{ticker}} {{interval}}m @ {{close}}")
alertcondition(isB1 and aBEFired, title="B1 BE",       message="B1 BREAK-EVEN - move stop to entry | {{ticker}} {{interval}}m @ {{close}}")
alertcondition(isB1 and aPart,    title="B1 Partial",  message="B1 PARTIAL - 25% closed at target; runner governs | {{ticker}} {{interval}}m @ {{close}}")
alertcondition(isB1 and aWin,     title="B1 TP",       message="B1 TP - close remaining (VWAP-cross / runner win) | {{ticker}} {{interval}}m @ {{close}}")
alertcondition(isB1 and aStop,    title="B1 SL",       message="B1 SL - close position (stop hit) | {{ticker}} {{interval}}m @ {{close}}")
alertcondition(isB1 and aEOD,     title="B1 EOD",      message="B1 EOD - end-of-day forced close | {{ticker}} {{interval}}m @ {{close}}")
// --- C1 · ATR 0.25 + 25% Partial + VWAP ---
alertcondition(isC1 and aEntryL,  title="C1 Buy",      message="C1 BUY - long breakout, buy at market | {{ticker}} {{interval}}m @ {{close}}")
alertcondition(isC1 and aEntryS,  title="C1 Sell",     message="C1 SELL - short breakout, sell short at market | {{ticker}} {{interval}}m @ {{close}}")
alertcondition(isC1 and aRevL,    title="C1 Rev Buy",  message="C1 REVERSAL BUY - risk-parity long at market | {{ticker}} {{interval}}m @ {{close}}")
alertcondition(isC1 and aRevS,    title="C1 Rev Sell", message="C1 REVERSAL SELL - risk-parity short at market | {{ticker}} {{interval}}m @ {{close}}")
alertcondition(isC1 and aBEFired, title="C1 BE",       message="C1 BREAK-EVEN - move stop to entry | {{ticker}} {{interval}}m @ {{close}}")
alertcondition(isC1 and aPart,    title="C1 Partial",  message="C1 PARTIAL - 25% closed at target; runner governs | {{ticker}} {{interval}}m @ {{close}}")
alertcondition(isC1 and aWin,     title="C1 TP",       message="C1 TP - close remaining (VWAP-cross / runner win) | {{ticker}} {{interval}}m @ {{close}}")
alertcondition(isC1 and aStop,    title="C1 SL",       message="C1 SL - close position (stop hit) | {{ticker}} {{interval}}m @ {{close}}")
alertcondition(isC1 and aEOD,     title="C1 EOD",      message="C1 EOD - end-of-day forced close | {{ticker}} {{interval}}m @ {{close}}")
// --- C2 · Fixed $2 Full-Exit (no partial) ---
alertcondition(isC2 and aEntryL,  title="C2 Buy",      message="C2 BUY - long breakout, buy at market | {{ticker}} {{interval}}m @ {{close}}")
alertcondition(isC2 and aEntryS,  title="C2 Sell",     message="C2 SELL - short breakout, sell short at market | {{ticker}} {{interval}}m @ {{close}}")
alertcondition(isC2 and aRevL,    title="C2 Rev Buy",  message="C2 REVERSAL BUY - risk-parity long at market | {{ticker}} {{interval}}m @ {{close}}")
alertcondition(isC2 and aRevS,    title="C2 Rev Sell", message="C2 REVERSAL SELL - risk-parity short at market | {{ticker}} {{interval}}m @ {{close}}")
alertcondition(isC2 and aBEFired, title="C2 BE",       message="C2 BREAK-EVEN - move stop to entry | {{ticker}} {{interval}}m @ {{close}}")
alertcondition(isC2 and aWin,     title="C2 TP",       message="C2 TP - close position (fixed $2 target win) | {{ticker}} {{interval}}m @ {{close}}")
alertcondition(isC2 and aStop,    title="C2 SL",       message="C2 SL - close position (stop hit) | {{ticker}} {{interval}}m @ {{close}}")
alertcondition(isC2 and aEOD,     title="C2 EOD",      message="C2 EOD - end-of-day forced close | {{ticker}} {{interval}}m @ {{close}}")

// ==================== SUMMARY TABLE ====================
var table tbl = table.new(position.top_right, 2, 15, border_width=1)
f_row(_r, _k, _v, _col) =>
    table.cell(tbl, 0, _r, _k, text_color=color.white, bgcolor=color.rgb(25,25,25), text_size=size.small)
    table.cell(tbl, 1, _r, _v, text_color=_col, bgcolor=color.rgb(25,25,25), text_size=size.small)
if barstate.islast and showTable
    wD = dayHasTrades ? (na(worstDay) ? dayPnl : math.min(worstDay, dayPnl)) : worstDay
    bD = dayHasTrades ? (na(bestDay) ? dayPnl : math.max(bestDay, dayPnl)) : bestDay
    tD = tradeDays + (dayHasTrades ? 1 : 0)
    wr = nTrades > 0 ? nSucc * 100.0 / nTrades : 0.0
    pf = grossL > 0 ? grossP / grossL : na
    exp = nTrades > 0 ? netPnl / nTrades : 0.0
    table.cell(tbl, 0, 0, "UDB-ORB v3", text_color=color.white, bgcolor=color.rgb(30,30,50), text_size=size.small)
    table.cell(tbl, 1, 0, str.substring(profile, 0, 2) + " · " + tpModeSel, text_color=color.aqua, bgcolor=color.rgb(30,30,50), text_size=size.small)
    f_row(1, "Trades", str.tostring(nTrades), color.yellow)
    f_row(2, "Win Rate", str.tostring(wr, "#.#") + "%", color.orange)
    f_row(3, "Net P&L (per unit)", (netPnl >= 0 ? "+" : "") + str.tostring(netPnl, "#.##"), netPnl >= 0 ? color.lime : color.red)
    f_row(4, "Profit Factor", na(pf) ? "n/a" : str.tostring(pf, "#.##"), na(pf) ? color.silver : (pf >= 1 ? color.lime : color.red))
    f_row(5, "Expectancy", (exp >= 0 ? "+" : "") + str.tostring(exp, "#.###"), exp >= 0 ? color.lime : color.red)
    f_row(6, "Best / Worst Day", (na(bD) ? "-" : "+" + str.tostring(bD, "#.##")) + " / " + (na(wD) ? "-" : str.tostring(wD, "#.##")), color.silver)
    f_row(7, "Trade Days", str.tostring(tD) + " / " + str.tostring(totalDays), color.aqua)
    f_row(8, "Today's TP dist", na(tpDist) ? "n/a" : "$" + str.tostring(tpDist, "#.##"), color.aqua)
    f_row(9, "Max Stop", "$" + str.tostring(maxCapSL, "#"), color.silver)
    f_row(10, "Skipped vol / wide", str.tostring(volSkipDays) + " / " + str.tostring(wideSkipDays), color.fuchsia)
    f_row(11, "Reversals", str.tostring(cRev), color.purple)
    f_row(12, "Wins (TP/runner)", str.tostring(cWin), color.lime)
    f_row(13, "Stops", str.tostring(cStop), color.orange)
    f_row(14, "EOD closes", str.tostring(cEOD), color.silver)
