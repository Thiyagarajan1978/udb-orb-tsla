# ============================================================
#  UDB-ORB-TSLA  —  Unified Daily Breakout (Adaptive TP + Reversal)
#  Copy to .env and fill in your real values.  NEVER commit .env.
# ============================================================

# ── Financial Modeling Prep (FMP) — sole data provider, stable API ──
# Get a key at https://site.financialmodelingprep.com/ and verify your
# intraday (5-minute) entitlement. Key is never logged.
FMP_API_KEY=your_fmp_key_here

# ── Email Alerts (Resend) — optional; leave blank to disable ────────
RESEND_API_KEY=re_your-resend-key
ALERT_FROM=onboarding@resend.dev
ALERT_TO=thiyagarajan.t@gmail.com

# ── Generic Webhook (Discord/Slack/custom) — optional ───────────────
# Any URL that accepts a JSON POST. Leave blank to disable.
ALERT_WEBHOOK_URL=

# ── Safety ──────────────────────────────────────────────────────────
# This system is ALERTS-ONLY. It never places broker orders.
ALERTS_ONLY=true
